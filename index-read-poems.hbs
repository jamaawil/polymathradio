{{!< default}}

<section class="collection-header collection-header--read">
    <p class="collection-header__eyebrow">&#9642; Read &middot; Poems</p>
    <h1>Poems</h1>
    <p>Poems published alongside the news.</p>
</section>

{{> "read-category-tabs" current="poems"}}

<section class="essay-archive">
    {{#foreach posts}}
    {{#if @first}}
    {{> "essay-feature"}}
    {{else}}
    {{> "essay-row"}}
    {{/if}}
    {{else}}
    <p class="course-grid__empty">No poems published yet.</p>
    {{/foreach}}
</section>

{{pagination}}

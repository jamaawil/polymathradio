{{!< default}}

{{#post}}
{{#has tag="read"}}
<div class="reading-progress" data-reading-progress aria-hidden="true"></div>
{{/has}}
<article class="post{{#has tag="watch, listen"}} post--episode{{/has}}{{#has tag="shop"}} post--product{{/has}}{{#has tag="stream"}} post--breaking{{/has}}{{#has tag="#dropcap"}} has-dropcap{{/has}}{{#has tag="#vertical"}} is-vertical{{/has}}">
    <header class="post__header">
        {{#has tag="watch"}}<p class="post__eyebrow">&#9656; Watch</p>{{/has}}
        {{#has tag="listen"}}<p class="post__eyebrow">&#9686; Listen</p>{{/has}}
        {{#has tag="read"}}<p class="post__eyebrow">Analysis &middot; The Record</p>{{/has}}
        {{#has tag="shop"}}<p class="post__eyebrow">&#9670; Shop</p>{{/has}}
        {{#has tag="stream"}}<p class="post__eyebrow">&#9670; Stream &middot; Breaking</p>{{/has}}
        {{#has tag="learn"}}<p class="post__eyebrow">&#9670; Learn{{#has tag="#lesson"}} &middot; Lesson{{/has}}</p>{{/has}}

        <h1 class="post__title">{{title}}</h1>

        {{#has tag="shop"}}
        {{#if custom_excerpt}}<p class="post__price">{{custom_excerpt}}</p>{{/if}}
        {{/has}}

        {{#has tag="read"}}
        <div class="post__byline">
            {{#if primary_author}}<span class="post__byline-name">BY {{primary_author.name}}</span><span>&middot;</span>{{/if}}
            <span>{{date format="MMM D YYYY"}}</span>
            {{#if reading_time}}<span>&middot;</span><span>{{reading_time}}</span>{{/if}}
        </div>
        <div class="post__rule"></div>
        {{else}}
        <div class="post__meta">
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMMM D, YYYY"}}</time>
            {{#if primary_author}}<span>&middot; {{primary_author.name}}</span>{{/if}}
        </div>
        {{/has}}
    </header>

    {{!-- Watch/Listen posts skip the static feature-image banner — the
          embedded video/audio the editor drops into the body (paste a
          YouTube/Spotify link, or use the Video/Audio card) is the hero
          instead, so it isn't fighting a duplicate image above it. --}}
    {{#has tag="watch, listen"}}
    <div class="post__listen">
        {{> "social-links"}}
    </div>
    {{else}}
    {{#if feature_image}}
    <div class="post__feature-image">
        <img
            srcset="{{img_url feature_image size="m"}} 1000w,
                    {{img_url feature_image size="l"}} 1600w"
            sizes="100vw"
            src="{{img_url feature_image size="l"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
    </div>
    {{/if}}
    {{/has}}

    {{#has tag="read"}}
    <aside class="post-toc" data-toc hidden>
        <p class="post-toc__label">In this piece</p>
        <ul class="post-toc__list" data-toc-list></ul>
    </aside>
    {{/has}}

    <div class="post__content">
        {{content}}
    </div>

    {{!-- Lesson nav + completion — opt in per post via an internal #lesson
          tag (checklist pattern: course = a tag grouping, lessons = posts
          tagged #lesson within it). Progress is localStorage-only; see
          assets/js/main.js and README for why a durable cross-device
          store would need something like Supabase, out of scope here. --}}
    {{#has tag="#lesson"}}
    <div class="lesson-complete-row">
        <button type="button" class="btn btn--gold" data-lesson-complete="{{slug}}">Mark as complete</button>
    </div>
    <nav class="lesson-nav" aria-label="Course navigation">
        {{#prev_post in="primary_tag"}}<a class="lesson-nav__prev" href="{{url}}">&larr; {{title}}</a>{{/prev_post}}
        {{#next_post in="primary_tag"}}<a class="lesson-nav__next" href="{{url}}">{{title}} &rarr;</a>{{/next_post}}
    </nav>
    {{/has}}

    {{#has tag="watch"}}
    {{#get "posts" filter="primary_tag:watch+id:-{{id}}" limit="4" as |relatedVideos|}}
    {{#if relatedVideos}}
    <div class="post__related">
        <h2 class="post__related-heading">More to watch</h2>
        <div class="post__related-grid">
            {{#foreach relatedVideos}}
            {{> "watch-card"}}
            {{/foreach}}
        </div>
    </div>
    {{/if}}
    {{/get}}
    {{/has}}

    {{#has tag="read"}}
    {{#get "posts" filter="primary_tag:read+id:-{{id}}" limit="3" as |relatedReading|}}
    {{#if relatedReading}}
    <div class="post__related">
        <h2 class="post__related-heading">Related reading</h2>
        <div class="post__related-grid">
            {{#foreach relatedReading}}
            {{> "article-card"}}
            {{/foreach}}
        </div>
    </div>
    {{/if}}
    {{/get}}
    {{/has}}

    {{#if primary_author.bio}}
    <div class="post__author">
        {{#if primary_author.profile_image}}
        <img src="{{primary_author.profile_image}}" alt="{{primary_author.name}}" loading="lazy">
        {{/if}}
        <div>
            <p class="post__author-name">{{primary_author.name}}</p>
            <p class="post__author-bio">{{primary_author.bio}}</p>
        </div>
    </div>
    {{/if}}

    <nav class="post__pagination" aria-label="More posts">
        {{#prev_post}}<a class="post__pagination-prev" href="{{url}}">&larr; {{title}}</a>{{/prev_post}}
        {{#next_post}}<a class="post__pagination-next" href="{{url}}">{{title}} &rarr;</a>{{/next_post}}
    </nav>

    {{!-- Native Ghost comments — member-gated per Settings -> Membership
          -> Access (currently "All members"). Renders in a sandboxed
          iframe Ghost controls; the theme can only size/space the
          wrapper, not restyle the comments UI itself. Skipped on Shop
          product pages, where a discussion thread doesn't fit. --}}
    {{#has tag="shop"}}{{else}}
    <div class="post__comments">
        {{comments}}
    </div>
    {{/has}}

    <div class="post__newsletter">
        {{> "newsletter-cta" heading="Enjoyed this one?" variant="end-of-post"}}
    </div>
</article>

{{#has tag="watch"}}{{> "schema-video"}}{{/has}}
{{#has tag="listen"}}{{> "schema-podcast"}}{{/has}}
{{/post}}

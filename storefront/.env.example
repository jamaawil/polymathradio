# Copy this file to .env.local and fill in real values. .env.local is
# gitignored — never commit real keys.

# Ghost site URL (no trailing slash), e.g. https://krinomedia.com
VITE_GHOST_API_URL=

# Content API key — Ghost Admin -> Settings -> Integrations -> Ghost Core
# Content API (or create a new Custom Integration and use its Content API
# key). This is safe to expose in client-side code: Content API keys are
# read-only and only ever return already-published content, the same
# thing a visitor could see on the site itself.
VITE_GHOST_CONTENT_API_KEY=

# Optional: where "Home"/"Watch"/"Listen" etc. links in the header/footer
# point. Defaults to https://krinomedia.com if unset.
VITE_MAIN_SITE_URL=

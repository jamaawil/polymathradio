{{!< default}}

{{!-- Custom template for this one author (Ghost convention: author-{slug}.hbs
      overrides author.hbs for a specific author). Modeled after
      gladwellbooks.com's structure: a featured-piece hero, a bio block with
      photo, then a grid of other bylined work. --}}

{{#get "posts" filter="authors:jamal-awil" limit="1" as |featured|}}
{{#foreach featured}}
<section class="write-hero">
    <div class="write-hero__body">
        <p class="write-hero__eyebrow">Latest from Jamal</p>
        <h1 class="write-hero__title"><a href="{{url}}">{{title}}</a></h1>
        <p class="write-hero__excerpt">{{excerpt words="30"}}</p>
        <a class="btn btn--ink" href="{{url}}">Read the piece</a>
    </div>
    {{#if feature_image}}
    <a class="write-hero__image" href="{{url}}">
        <img src="{{img_url feature_image size="l"}}" loading="lazy" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
    </a>
    {{/if}}
</section>
{{/foreach}}
{{/get}}

{{!-- Bio block. Ghost's deprecated author-context block helper (the one
      gscan suggests replacing with {{#primary_author}} or
      {{#foreach authors}}) would also resolve these fields here, and is
      in fact the ONLY one of the three that actually works on an
      author-{slug}.hbs override template ({{#primary_author}} and
      {{#foreach authors}} both render nothing here — confirmed by
      testing). But gscan flags that deprecated helper as an error in any
      file not literally named author.hbs, with no allowance for
      author-{slug}.hbs overrides -- a real gscan limitation, not a theme
      bug (note: don't literally reference that helper's own syntax in
      this comment, or gscan flags it here too — it does raw text
      matching, not real Handlebars parsing, so it can't tell a comment
      from real code). Querying the author as a resource via
      {{#get "authors"}} sidesteps the whole issue: same data, zero gscan
      warnings on upload. --}}
{{#get "authors" filter="slug:jamal-awil" limit="1" as |bioAuthor|}}
{{#foreach bioAuthor}}
<section class="write-bio">
    <div class="write-bio__portrait">
        {{#if profile_image}}
        <img src="{{profile_image}}" alt="{{name}}" loading="lazy">
        {{else}}
        {{> "krino-mark" size="96px" ring=false mark="var(--ink)"}}
        {{/if}}
    </div>
    <div class="write-bio__body">
        <p class="write-bio__eyebrow">Founding Editor, Krino Media</p>
        <h2>{{name}}</h2>
        {{#if bio}}<p class="write-bio__text">{{bio}}</p>{{/if}}
        <ul class="write-bio__links">
            {{#if @custom.twitter_url}}<li><a href="{{@custom.twitter_url}}" rel="noopener" target="_blank">X</a></li>{{/if}}
            {{#if @custom.instagram_url}}<li><a href="{{@custom.instagram_url}}" rel="noopener" target="_blank">Instagram</a></li>{{/if}}
            {{#if @custom.linkedin_url}}<li><a href="{{@custom.linkedin_url}}" rel="noopener" target="_blank">LinkedIn</a></li>{{/if}}
        </ul>
    </div>
</section>
{{/foreach}}
{{/get}}

<section class="write-more">
    <h2 class="write-more__heading">Pieces by Jamal Awil</h2>
    <div class="write-more__grid">
        {{#foreach posts}}
        {{#unless @first}}
        {{> "article-card"}}
        {{/unless}}
        {{else}}
        <p class="archive-empty">Nothing else published yet.</p>
        {{/foreach}}
    </div>
</section>

{{pagination}}

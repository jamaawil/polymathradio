{{!< default}}

{{!-- Homepage cover photo: uses Ghost's native Publication cover image
      (Admin -> Settings -> General -> Publication cover), so it's editable
      without touching code. No upload = no background, just the plain
      brand backdrop underneath. --}}
<section class="hero{{#if @site.cover_image}} hero--has-cover{{/if}}"{{#if @site.cover_image}} style="background-image: url('{{img_url @site.cover_image size="xl"}}')"{{/if}}>
    <div class="hero__grid">
        <div class="hero__copy">
            <p class="hero__eyebrow">Independent U.S. political media</p>
            <h1 class="hero__title">Sift the noise.</h1>
            <p class="hero__tagline">{{@custom.hero_tagline}}</p>
            <div class="hero__actions">
                <a class="btn btn--ink" href="{{@site.url}}/watch/">&#9656; Watch the latest</a>
                <a class="btn btn--outline" href="{{@site.url}}/about/">How we work</a>
            </div>
        </div>

        {{#get "posts" filter="tag:[watch,listen]" limit="1" as |featured|}}
        {{#foreach featured}}
        {{> "episode-spotlight"}}
        {{/foreach}}
        {{/get}}
    </div>
</section>

{{#get "posts" filter="tag:breakdown" limit="1" as |breakdown|}}
{{#if breakdown}}
<section class="breakdown-section">
    {{#foreach breakdown}}
    {{> "breakdown-card"}}
    {{/foreach}}
</section>
{{/if}}
{{/get}}

{{#get "posts" filter="primary_tag:watch" limit="3" as |watchPosts|}}
{{#if watchPosts}}
<section class="article-list">
    <div class="article-list__header">
        <h2>Latest on Watch</h2>
        <a href="{{@site.url}}/watch/">All videos &rarr;</a>
    </div>
    <div class="article-list__items">
        {{#foreach watchPosts}}
        {{> "watch-card"}}
        {{/foreach}}
    </div>
</section>
{{/if}}
{{/get}}


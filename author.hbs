{{!< default}}

{{!-- see author-jamal-awil.hbs for why {{#author}} stays despite gscan's
      deprecation warning: removing it left {{name}} empty on this
      template. --}}
{{#author}}
<section class="collection-header collection-header--author">
    {{#if profile_image}}
    <img class="author-avatar" src="{{profile_image}}" alt="{{name}}" loading="lazy">
    {{/if}}
    <h1>{{name}}</h1>
    {{#if bio}}<p>{{bio}}</p>{{/if}}
    <ul class="author-links">
        {{#if website}}<li><a href="{{website}}" rel="noopener" target="_blank">Website</a></li>{{/if}}
        {{#if twitter}}<li><a href="https://twitter.com/{{twitter}}" rel="noopener" target="_blank">Twitter</a></li>{{/if}}
    </ul>
</section>
{{/author}}

<section class="article-grid">
    {{#foreach posts}}
    {{> "article-card"}}
    {{/foreach}}
</section>

{{pagination}}

{{!< default}}

<section class="collection-header collection-header--read">
    <p class="collection-header__eyebrow">&#9642; Read &middot; Book Review</p>
    <h1>Book Review</h1>
    <p>An online-only review of books and the arguments about them.</p>
</section>

{{> "read-category-tabs" current="book-review"}}

<section class="essay-archive">
    {{#foreach posts}}
    {{#if @first}}
    {{> "essay-feature"}}
    {{else}}
    {{> "essay-row"}}
    {{/if}}
    {{else}}
    <p class="course-grid__empty">No reviews published yet.</p>
    {{/foreach}}
</section>

{{pagination}}

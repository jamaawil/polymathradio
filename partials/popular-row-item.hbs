{{!-- One item in the homepage "Most Popular" row: title + meta on the
      left, small square thumbnail on the right. Curated by tagging a post
      #popular in Admin -- there's no view-count tracking in this Ghost
      install, so "popular" here means editor's pick, same opt-in pattern
      as the #breakdown tag. Expects post context. --}}
<article class="popular-item">
    <div class="popular-item__body">
        <h3 class="popular-item__title"><a href="{{url}}">{{title}}</a></h3>
        <div class="popular-item__meta">
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM D"}}</time>
            {{#if primary_author}}<span>&middot;</span><span>{{primary_author.name}}</span>{{/if}}
        </div>
    </div>
    <a class="popular-item__image" href="{{url}}">
        {{#if feature_image}}
        <img
            src="{{img_url feature_image size="xxs"}}"
            loading="lazy"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
        {{else}}
        <span class="popular-item__cover-fallback">
            {{> "krino-mark" size="20px" ring=false mark="var(--gold)"}}
        </span>
        {{/if}}
        {{#has tag="watch, listen"}}
        <span class="popular-item__play" aria-hidden="true"></span>
        {{/has}}
    </a>
</article>

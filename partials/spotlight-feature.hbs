{{!-- Big left-hand feature inside a spotlight-section (image + large serif
      headline below it + excerpt + byline). Expects post context. --}}
<article class="spotlight-feature">
    <a class="spotlight-feature__image" href="{{url}}">
        {{#if feature_image}}
        <img
            srcset="{{img_url feature_image size="s"}} 600w,
                    {{img_url feature_image size="m"}} 1000w"
            sizes="(max-width: 900px) 100vw, 480px"
            src="{{img_url feature_image size="m"}}"
            loading="lazy"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
        {{else}}
        <span class="spotlight-feature__cover-fallback">
            {{> "krino-mark" size="48px" ring=false mark="var(--gold)"}}
        </span>
        {{/if}}
        {{#has tag="watch, listen"}}
        <span class="spotlight-feature__play" aria-hidden="true"></span>
        {{/has}}
    </a>
    <div class="spotlight-feature__body">
        <h3 class="spotlight-feature__title"><a href="{{url}}">{{title}}</a></h3>
        <p class="spotlight-feature__excerpt">{{excerpt words="22"}}</p>
        <div class="spotlight-feature__meta">
            {{#if primary_author}}<span>{{primary_author.name}}</span><span>&middot;</span>{{/if}}
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM D, YYYY"}}</time>
        </div>
    </div>
</article>

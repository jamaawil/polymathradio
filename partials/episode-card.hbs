<article class="episode-card">
    <a class="episode-card__art" href="{{url}}">
        {{#if feature_image}}
        <img
            srcset="{{img_url feature_image size="s"}} 600w,
                    {{img_url feature_image size="m"}} 1000w"
            sizes="(max-width: 600px) 100vw, 360px"
            src="{{img_url feature_image size="m"}}"
            loading="lazy"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
        {{/if}}
        <span class="episode-card__play" aria-hidden="true"></span>
    </a>
    <div class="episode-card__body">
        <time class="episode-card__date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM D, YYYY"}}</time>
        <h3 class="episode-card__title"><a href="{{url}}">{{title}}</a></h3>
        <p class="episode-card__excerpt">{{excerpt words="20"}}</p>
    </div>
</article>

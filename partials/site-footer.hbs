<footer class="site-footer">
    <div class="site-footer__newsletter">
        {{> "newsletter-cta" heading="The week, weighed on the evidence" variant="footer"}}
    </div>

    <div class="site-footer__grid">
        <div class="site-footer__about">
            <span class="site-header__mark">{{> "krino-mark" size="30px" ring=false mark="var(--bone)"}}</span>
            <p class="site-footer__tagline">Sift the noise.</p>
            <p>{{@site.description}}</p>
        </div>

        <div class="site-footer__nav">
            <h3>Channels</h3>
            <ul>
                <li><a href="{{@site.url}}/watch/">Watch</a></li>
                <li><a href="{{@site.url}}/listen/">Listen</a></li>
                <li><a href="{{@site.url}}/read/">Read</a></li>
                <li><a href="{{@site.url}}/learn/">Learn</a></li>
            </ul>
        </div>

        <div class="site-footer__nav">
            <h3>Company</h3>
            <ul>
                <li><a href="{{@site.url}}/author/jamal-awil/">Write</a></li>
                <li><a href="{{@site.url}}/about/">About Us</a></li>
                <li><a href="{{@site.url}}/contact/">Contact</a></li>
                <li><a href="{{@site.url}}/advertise/">Advertise</a></li>
            </ul>
        </div>

        <div class="site-footer__listen">
            <h3>Follow</h3>
            {{> "social-links"}}
        </div>
    </div>

    <div class="site-footer__meta">
        <p>&copy; {{date format="YYYY"}} {{@site.title}}. Independent U.S. political media.</p>
    </div>
</footer>

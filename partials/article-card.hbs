<article class="article-card">
    {{#if feature_image}}
    <a class="article-card__image" href="{{url}}">
        <img
            srcset="{{img_url feature_image size="s"}} 600w,
                    {{img_url feature_image size="m"}} 1000w"
            sizes="(max-width: 600px) 100vw, 400px"
            src="{{img_url feature_image size="m"}}"
            loading="lazy"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
    </a>
    {{/if}}
    <div class="article-card__body">
        <p class="article-card__eyebrow">Analysis &middot; The Record</p>
        <h3 class="article-card__title"><a href="{{url}}">{{title}}</a></h3>
        <p class="article-card__excerpt">{{excerpt words="24"}}</p>
        <div class="article-card__meta">
            {{#if primary_author}}<span>{{primary_author.name}}</span><span>&middot;</span>{{/if}}
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM D, YYYY"}}</time>
            {{#if reading_time}}<span>&middot;</span><span>{{reading_time}}</span>{{/if}}
        </div>
    </div>
</article>

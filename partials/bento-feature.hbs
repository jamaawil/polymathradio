{{!-- Big center card of the homepage bento grid: full-width image, serif
      headline below it (not overlaid), excerpt, byline. Expects post
      context. --}}
<article class="bento-feature">
    <a class="bento-feature__image" href="{{url}}">
        {{#if feature_image}}
        <img
            srcset="{{img_url feature_image size="m"}} 1000w,
                    {{img_url feature_image size="l"}} 1600w"
            sizes="(max-width: 900px) 100vw, 640px"
            src="{{img_url feature_image size="l"}}"
            loading="lazy"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
        {{else}}
        <span class="bento-feature__cover-fallback">
            {{> "krino-mark" size="56px" ring=false mark="var(--gold)"}}
        </span>
        {{/if}}
    </a>
    <div class="bento-feature__body">
        <h2 class="bento-feature__title"><a href="{{url}}">{{title}}</a></h2>
        <p class="bento-feature__excerpt">{{excerpt words="26"}}</p>
        <div class="bento-feature__meta">
            {{#if primary_author}}<span>{{primary_author.name}}</span><span>&middot;</span>{{/if}}
            <time datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMM D, YYYY"}}</time>
        </div>
    </div>
</article>

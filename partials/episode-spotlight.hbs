{{!-- Dark "featured episode" panel — matches the brand guideline homepage
      hero mockup exactly (arc watermark, gold eyebrow, Fraunces headline,
      gold play button + duration/meta row). Expects to be inside a
      {{#foreach}} or {{#get}} post loop. --}}
<div class="episode-spotlight">
    <div class="episode-spotlight__watermark" aria-hidden="true">
        <svg viewBox="0 0 200 200" width="100%" height="100%" fill="none">
            <circle cx="100" cy="100" r="48" stroke="var(--gold)" stroke-width="2" opacity="0.5"></circle>
            <circle cx="100" cy="100" r="82" stroke="var(--gold)" stroke-width="2" opacity="0.25"></circle>
        </svg>
    </div>
    <p class="episode-spotlight__eyebrow">Latest episode · {{date format="MMM D"}}</p>
    <h3 class="episode-spotlight__title"><a href="{{url}}">{{title}}</a></h3>
    <div class="episode-spotlight__meta">
        <a class="episode-spotlight__play" href="{{url}}" aria-label="Play {{title}}">
            <span class="episode-spotlight__play-icon" aria-hidden="true"></span>
        </a>
        <span>Watch &amp; Listen</span>
    </div>
</div>

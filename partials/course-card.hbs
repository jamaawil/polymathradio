{{!-- MasterClass Certificates-style course card, in Krino's own palette.
      Uses a generic monogram avatar rather than a fabricated instructor
      photo — swap the class "course-card--placeholder" off once real
      courses/instructors exist. Expects post context. --}}
<article class="course-card course-card--placeholder">
    <a class="course-card__art" href="{{url}}">
        {{#if feature_image}}
        <img
            srcset="{{img_url feature_image size="s"}} 600w,
                    {{img_url feature_image size="m"}} 1000w"
            sizes="(max-width: 600px) 100vw, 360px"
            src="{{img_url feature_image size="m"}}"
            loading="lazy"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
        {{else}}
        <span class="course-card__avatar">{{> "krino-mark" size="44px" ring=false mark="var(--gold)"}}</span>
        {{/if}}
        <span class="course-card__badge">Coming soon</span>
    </a>
    <div class="course-card__body">
        <div class="topic-chips topic-chips--small topic-chips--on-dark">{{tags visibility="public" from="2" separator=" &middot; "}}</div>
        <h3 class="course-card__title"><a href="{{url}}">{{title}}</a></h3>
        <p class="course-card__excerpt">{{excerpt words="18"}}</p>
        <div class="course-card__footer">
            <span class="course-card__certificate">&#127894; Certificate program</span>
            <span class="course-card__instructor">Krino Editorial</span>
        </div>
    </div>
</article>

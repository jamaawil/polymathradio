{{!-- VideoObject JSON-LD for #watch posts. Google requires contentUrl OR
      embedUrl, and duration is strongly recommended — Ghost has no
      structured field for either (video lives inside {{content}} as a
      pasted embed or uploaded file, not a dedicated post property), so
      this ships the fields we can know for certain. For a specific
      episode where exact embedUrl/duration matter for Search rich
      results, add them per-post via Post settings -> Code injection
      (head) rather than guessing here.

      Every dynamic string below is wrapped in explicit "..." quotes —
      {{title}}/{{meta_description}}/{{@site.title}} do NOT self-quote,
      and Handlebars' default double-stash escaping turns a literal "
      inside the value into &quot; (not a raw quote), so quoting +
      default escaping is what keeps this valid JSON. Shipping this
      unquoted previously produced literally invalid JSON-LD (caught in
      this theme's pre-release QA pass) -- worth remembering if you add
      more dynamic fields here later. --}}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": "{{title}}",
    "url": "{{url absolute="true"}}",
    "uploadDate": "{{date format="YYYY-MM-DD"}}",
    {{#if meta_description}}"description": "{{meta_description}}",{{/if}}
    {{#if feature_image}}"thumbnailUrl": ["{{img_url feature_image size="l"}}"],{{/if}}
    "publisher": {
        "@type": "Organization",
        "name": "{{@site.title}}",
        "logo": {
            "@type": "ImageObject",
            "url": "{{#if @site.icon}}{{@site.icon}}{{else}}{{@site.url}}/favicon.ico{{/if}}"
        }
    }
}
</script>

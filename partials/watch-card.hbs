<article class="watch-card">
    <a class="watch-card__image" href="{{url}}">
        {{#if feature_image}}
        <img
            srcset="{{img_url feature_image size="s"}} 600w,
                    {{img_url feature_image size="m"}} 1000w"
            sizes="(max-width: 600px) 100vw, 360px"
            src="{{img_url feature_image size="m"}}"
            loading="lazy"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
        {{/if}}
        <span class="watch-card__play" aria-hidden="true"></span>
    </a>
    <div class="watch-card__body">
        <div class="topic-chips topic-chips--small">{{tags visibility="public" from="2" separator=" &middot; "}}</div>
        <h3 class="watch-card__title"><a href="{{url}}">{{title}}</a></h3>
        <p class="watch-card__excerpt">{{excerpt words="16"}}</p>
    </div>
</article>

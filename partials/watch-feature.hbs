{{!-- Lead story treatment for the /watch/ archive — Vox Explainers-style:
      one big feature card up top, dense grid below. Expects post context. --}}
<article class="watch-feature">
    <a class="watch-feature__image" href="{{url}}">
        {{#if feature_image}}
        <img
            srcset="{{img_url feature_image size="m"}} 1000w,
                    {{img_url feature_image size="l"}} 1600w"
            sizes="100vw"
            src="{{img_url feature_image size="l"}}"
            loading="lazy"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
        {{/if}}
        <span class="watch-feature__play" aria-hidden="true"></span>
    </a>
    <div class="watch-feature__body">
        <div class="topic-chips">{{tags visibility="public" from="2" separator=" &middot; "}}</div>
        <h2 class="watch-feature__title"><a href="{{url}}">{{title}}</a></h2>
        <p class="watch-feature__excerpt">{{excerpt words="28"}}</p>
        <a class="btn btn--ink" href="{{url}}">&#9656; Watch now</a>
    </div>
</article>

{{!< default}}

<section class="collection-header collection-header--read">
    <p class="collection-header__eyebrow">&#9642; Read &middot; Fiction</p>
    <h1>Fiction</h1>
    <p>Short fiction from the Krino newsroom and friends of the magazine.</p>
</section>

{{> "read-category-tabs" current="fiction"}}

<section class="essay-archive">
    {{#foreach posts}}
    {{#if @first}}
    {{> "essay-feature"}}
    {{else}}
    {{> "essay-row"}}
    {{/if}}
    {{else}}
    <p class="course-grid__empty">No fiction published yet.</p>
    {{/foreach}}
</section>

{{pagination}}

{{!< default}}

{{#post}}
<article class="page">
    {{#match @page.show_title_and_feature_image}}
    <header class="page__header">
        <h1 class="page__title">{{title}}</h1>
    </header>

    {{#if feature_image}}
    <div class="page__feature-image">
        <img src="{{img_url feature_image size="l"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy">
    </div>
    {{/if}}
    {{/match}}

    <div class="page__content">
        {{content}}
    </div>

    <div class="page__newsletter">
        {{> "newsletter-cta" variant="page-end"}}
    </div>
</article>
{{/post}}

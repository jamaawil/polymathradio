<!doctype html>
<html lang="{{@site.locale}}" data-theme="auto">
<head>
    <meta charset="utf-8">
    <title>{{meta_title}}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="{{@custom.ink}}">

    {{!-- Ghost injects meta tags, canonical URL, OG/Twitter cards, JSON-LD, RSS link, etc. --}}
    {{ghost_head}}

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="{{asset "css/screen.css"}}">
    <link rel="manifest" href="{{asset "manifest.json"}}">
    <style>:root{--gold: {{@custom.gold}}; --ink: {{@custom.ink}};}</style>
    <script>
        (function () {
            var stored = localStorage.getItem("krino-theme");
            var theme = stored || "auto";
            document.documentElement.setAttribute("data-theme", theme);
        })();
    </script>
</head>
<body class="{{body_class}}{{#if @member}} member-logged-in{{/if}}">
    <a class="skip-link" href="#main-content">Skip to content</a>

    {{> "site-header"}}

    <main id="main-content">
        {{{body}}}
    </main>

    {{> "site-footer"}}

    {{!-- Sticky mini-player: mirrors whichever native <audio> element
          (Koenig Audio card) is playing on the current page. Page-scoped,
          not cross-navigation — see README for why true persistent
          playback across page loads would need a bigger architecture
          change (a pjax/SPA layer) than a standard Ghost theme takes on. --}}
    <div class="sticky-player" data-sticky-player hidden>
        <button type="button" class="sticky-player__toggle" data-sticky-player-toggle aria-label="Play or pause">Pause</button>
        <span class="sticky-player__title" data-sticky-player-title></span>
        <button type="button" class="sticky-player__close" data-sticky-player-close aria-label="Close player">&times;</button>
    </div>

    <script src="{{asset "js/main.js"}}" defer></script>
    <script>
        if ("serviceWorker" in navigator) {
            window.addEventListener("load", function () {
                navigator.serviceWorker.register("/service-worker/", { scope: "/" }).catch(function () {});
            });
        }
    </script>
    {{ghost_foot}}
</body>
</html>
